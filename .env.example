# Copy to .env.local and fill in real values. .env.local is gitignored.

# GitHub PAT for repo pushes (fine-grained, scoped to thefranchisorblueprint)
GITHUB_TOKEN=

# Vercel API token (for deploys, env var management, log reading)
VERCEL_TOKEN=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe Dashboard → Products → "The Blueprint" ($2,997 one-time)
STRIPE_PRICE_BLUEPRINT=

# Supabase (auth + DB for the customer portal)
# Project Settings → API → Project URL, anon key, service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Account-level Personal Access Token (sbp_...) for setup-time admin tasks
SUPABASE_ACCESS_TOKEN=

# ── ActiveCampaign ─────────────────────────────────────────────────────────
# AC → Settings → Developer → API URL + Key
ACTIVECAMPAIGN_API_URL=
ACTIVECAMPAIGN_API_KEY=
# Single "TFB Master" list ID (Lists → click → URL = /list/<ID>).
# Tags do segmentation; one list keeps subscriptions clean.
ACTIVECAMPAIGN_LIST_MASTER=
# Optional AC custom-field IDs (Settings → Manage Fields). Leave blank
# to skip; only configured fields get pushed.
ACTIVECAMPAIGN_FIELD_BUSINESS_NAME=
ACTIVECAMPAIGN_FIELD_ANNUAL_REVENUE=
ACTIVECAMPAIGN_FIELD_PROGRAM_INTEREST=
ACTIVECAMPAIGN_FIELD_MESSAGE=

# Calendly
CALENDLY_API_KEY=

# Pointerpro
POINTERPRO_API_KEY=

# ── SEO / Analytics ────────────────────────────────────────────────────────
# GA4 measurement ID (G-XXXXXXXXXX). Loads gtag in app/layout.tsx if set.
# Get from https://analytics.google.com → Admin → Data Streams
#
# Production stream (already configured in Vercel env vars):
#   Stream name:    The Franchisor Blueprint
#   Stream URL:     https://www.thefranchisorblueprint.com
#   Stream ID:      14627797338
#   Measurement ID: G-MW8VC4CCK9
NEXT_PUBLIC_GA4_ID=

# Measurement Protocol API secret for SERVER-SIDE event tracking
# (used by the Stripe webhook to fire authoritative `purchase` events
# that bypass ad-blockers). Get one at:
#   GA4 Admin → Data Streams → web stream → "Measurement Protocol API secrets"
GA4_MP_API_SECRET=

# Google Search Console domain verification (meta-tag content value only,
# not the full <meta> tag). Get from https://search.google.com/search-console
NEXT_PUBLIC_GSC_VERIFICATION=
# Bing Webmaster verification (msvalidate.01 content value).
NEXT_PUBLIC_BING_VERIFICATION=
