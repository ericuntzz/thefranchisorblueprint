# Copy to .env.local and fill in real values. .env.local is gitignored.

# GitHub PAT for repo pushes (fine-grained, scoped to thefranchisorblueprint)
GITHUB_TOKEN=

# Vercel API token (for deploys, env var management, log reading)
VERCEL_TOKEN=

# Stripe
# Toggle to "true" once live Stripe keys are wired. While "false" (or
# unset), the public Blueprint buy buttons route to /strategy-call
# (founding-member kickoff call) instead of test-mode Stripe checkout.
NEXT_PUBLIC_STRIPE_LIVE=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe Dashboard → Products → "The Blueprint" ($2,997 one-time)
STRIPE_PRICE_BLUEPRINT=
# Additional purchasable product Price IDs used by the portal/upgrade flows
STRIPE_PRICE_BLUEPRINT_PLUS=
STRIPE_PRICE_NAVIGATOR=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_SAMPLE_CALL=
STRIPE_PRICE_PHASE_COACHING=
STRIPE_PRICE_UPGRADE_1_2=
STRIPE_PRICE_UPGRADE_1_3=
STRIPE_PRICE_UPGRADE_2_3=
# Optional coupon ID for 48-hour upgrade promos. Defaults to UPGRADE10 in code.
STRIPE_COUPON_UPGRADE10=
# 5% pay-in-full discount — applies to any tier when customer chooses pay in full
STRIPE_COUPON_PAY_IN_FULL=
# Installment-plan recurring monthly Price IDs
STRIPE_PRICE_BLUEPRINT_INSTALLMENT=
STRIPE_PRICE_NAVIGATOR_INSTALLMENT=
STRIPE_PRICE_BUILDER_INSTALLMENT=
# Builder $13K down-payment one-time Price ID (precedes the 6 installments)
STRIPE_PRICE_BUILDER_DOWN=

# Supabase (auth + DB for the customer portal)
# Project Settings → API → Project URL, anon key, service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Account-level Personal Access Token (sbp_...) for setup-time admin tasks
SUPABASE_ACCESS_TOKEN=

# ── Internal lead notification ─────────────────────────────────────────────
# Where /api/contact and /api/subscribe send the "new lead!" email so Jason
# knows in real time. Defaults to team@thefranchisorblueprint.com if unset.
INTERNAL_NOTIFICATION_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
CRON_SECRET=

# ── ActiveCampaign — REMOVED ───────────────────────────────────────────────
# (Replaced 2026-04-28 with bespoke Supabase + Resend stack.
# /contact + /blog → contact_submissions / newsletter_subscribers tables.
# Autoresponders + internal notifications → scheduled_emails queue + drip cron.
# Keep this comment so future search for ACTIVECAMPAIGN finds the trail.)

# Calendly
CALENDLY_API_KEY=

# Pointerpro
POINTERPRO_API_KEY=

# ── SEO / Analytics ────────────────────────────────────────────────────────
# GA4 measurement ID (G-XXXXXXXXXX). Loads gtag in app/layout.tsx if set.
# Get from https://analytics.google.com → Admin → Data Streams
#
# Production stream (already configured in Vercel env vars):
#   Stream name:    The Franchisor Blueprint
#   Stream URL:     https://www.thefranchisorblueprint.com
#   Stream ID:      14627797338
#   Measurement ID: G-MW8VC4CCK9
NEXT_PUBLIC_GA4_ID=

# Measurement Protocol API secret for SERVER-SIDE event tracking
# (used by the Stripe webhook to fire authoritative `purchase` events
# that bypass ad-blockers). Get one at:
#   GA4 Admin → Data Streams → web stream → "Measurement Protocol API secrets"
GA4_MP_API_SECRET=

# Canonical production site URL. Defaults to https://www.thefranchisorblueprint.com.
NEXT_PUBLIC_SITE_URL=

# Google Search Console domain verification (meta-tag content value only,
# not the full <meta> tag). Get from https://search.google.com/search-console
NEXT_PUBLIC_GSC_VERIFICATION=
# Bing Webmaster verification (msvalidate.01 content value).
NEXT_PUBLIC_BING_VERIFICATION=
